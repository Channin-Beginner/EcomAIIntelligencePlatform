MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=mall

JWT_SECRET=ecomai-jwt-secret-change-in-production
JWT_EXPIRE_SECONDS=604800
TOKEN_HEAD=Bearer 

ADMIN_PORT=8080
PORTAL_PORT=8085

# 火山引擎豆包（方舟 OpenAI 兼容接口）
# 在火山方舟控制台创建推理接入点，LLM_MODEL 填接入点 ID（如 ep-xxxxxxxx）
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your_ark_api_key_here
LLM_MODEL=ep-your-endpoint-id
LLM_TIMEOUT=60
