{
  "version": "1.0",
  "data_window": "2025-01-01 00:00:00 ~ 2026-01-01 00:00:00",
  "allowed_tables": {
    "ads_order_daily": {
      "description": "日订单与 GMV 汇总",
      "columns": ["stat_date", "order_count", "gmv", "paid_order_count", "member_count", "updated_at"]
    },
    "ads_order_hourly": {
      "description": "按小时订单与 GMV",
      "columns": ["stat_date", "stat_hour", "order_count", "gmv", "updated_at"]
    },
    "ads_funnel_daily": {
      "description": "转化漏斗各阶段事件数",
      "columns": ["stat_date", "pv_count", "click_count", "cart_count", "fav_count", "order_event_count", "updated_at"]
    },
    "ads_member_active": {
      "description": "日活跃 UV/PV",
      "columns": ["stat_date", "uv", "pv", "active_member_count", "updated_at"]
    },
    "ads_region_sales": {
      "description": "省份维度销售",
      "columns": ["stat_date", "province", "order_count", "gmv", "updated_at"]
    },
    "ads_product_top": {
      "description": "热销商品日榜",
      "columns": ["stat_date", "rank_num", "product_id", "product_name", "order_count", "gmv", "updated_at"]
    },
    "ads_order_status": {
      "description": "订单状态分布",
      "columns": ["stat_date", "status", "status_name", "order_count", "updated_at"]
    },
    "ecom_event_log": {
      "description": "用户行为事件（pv/click/cart/fav/order）",
      "columns": ["event_id", "member_id", "product_id", "event_type", "event_time", "session_id", "source", "page_path", "extra_json"]
    },
    "oms_order": {
      "description": "订单主表（delete_status=0 为有效）",
      "columns": ["id", "member_id", "order_sn", "create_time", "pay_amount", "status", "receiver_province", "delete_status"]
    },
    "oms_order_item": {
      "description": "订单明细",
      "columns": ["id", "order_id", "product_id", "product_name", "product_quantity", "product_price", "real_amount"]
    },
    "pms_product": {
      "description": "商品 SPU",
      "columns": ["id", "name", "brand_id", "product_category_id", "sale", "price", "publish_status", "delete_status"]
    },
    "pms_brand": {
      "description": "品牌",
      "columns": ["id", "name", "show_status"]
    }
  },
  "rules": [
    "仅允许 SELECT 单条语句",
    "查询必须带 LIMIT，最大 500",
    "时间过滤优先使用 stat_date 或 DATE(create_time)/DATE(event_time)",
    "GMV 优先使用 ads 表 gmv 字段；明细可用 oms_order.pay_amount",
    "有效订单：oms_order.delete_status = 0"
  ]
}
